# froot configuration. Copy to `.env` (gitignored) for local runs, or set these
# in the environment. No real secrets belong in this example file.

# GitHub token — needs contents:write + pull_requests:write on the target repos
# (it pushes a branch and opens a PR; it never merges). FROOT_GITHUB_TOKEN is
# preferred; a plain GITHUB_TOKEN is not read (use the FROOT_-prefixed name).
FROOT_GITHUB_TOKEN=ghp_replace_me

# Comma-separated owner/name repos to point the loops at. A bare slug is an npm
# repo; suffix with @uv for a Python/uv repo (e.g. acme/pylib@uv). Both loops
# (dependency-patch and the determinism reviewer) read this same list.
FROOT_REPOS=octocat/hello-world

# How often each repo's dependency-patch scan loop ticks (seconds; default
# 86400 = daily).
FROOT_SCAN_INTERVAL_SECONDS=86400

# Determinism-review loop (advisory PR comments where a Temporal workflow risks a
# replay-nondeterminism hazard). On by default; started by `python -m
# froot.review_starter`. Poll cadence and first-party call-depth are optional.
# FROOT_REVIEW_ENABLED=1
# FROOT_REVIEW_POLL_INTERVAL_SECONDS=300
# FROOT_REVIEW_DEPTH=2

# Read-only read-model dashboard the worker also serves (on by default).
# FROOT_DASHBOARD_ENABLED=1
# FROOT_DASHBOARD_PORT=8080

# Temporal connection (these defaults are for a local server; the cluster
# deployment sets them to the in-cluster frontend / namespace / queue).
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=froot

# The judge model (a local Ollama by default) — used by both the changelog-risk
# judge and the determinism reviewer's frontier judge.
FROOT_OLLAMA_MODEL=gemma4:e4b
FROOT_OLLAMA_URL=http://localhost:11434/v1

# OpenTelemetry off unless truthy (the cluster sets FROOT_OTEL=1).
FROOT_OTEL=0
