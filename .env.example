# froot configuration. Copy to `.env` (gitignored) for local runs, or set these
# in the environment. No real secrets belong in this example file.

# GitHub token — needs contents:write + pull_requests:write on the target repos
# (it pushes a branch and opens a PR; it never merges). FROOT_GITHUB_TOKEN is
# preferred; a plain GITHUB_TOKEN is not read (use the FROOT_-prefixed name).
FROOT_GITHUB_TOKEN=ghp_replace_me

# Comma-separated owner/name repos to point the loop at (npm projects on GitHub).
FROOT_REPOS=octocat/hello-world

# How often each repo's scan loop ticks (seconds; default 86400 = daily).
FROOT_SCAN_INTERVAL_SECONDS=86400

# Which maintenance loops to run on each repo (comma-separated). Defaults to
# dependency-patch alone; add security-patch to also bump deps that clear a known
# advisory (OSV-sourced). Each loop runs on its own branch/label namespace.
FROOT_LOOPS=dependency-patch,security-patch

# Source-level a11y-review loop (advisory PR comments on Vue/JSX template gaps).
# Off by default — a notifier loop opts in deliberately. Set to 1 to enable, then
# run `make start-a11y` (or apply manage/start-a11y.yaml in the cluster). It is a
# separate ring from FROOT_LOOPS (which selects the bump loops), like the
# determinism reviewer's FROOT_REVIEW_ENABLED.
FROOT_A11Y_ENABLED=0

# Loop hygiene (both default on). close_on_red closes a bump's PR and deletes
# its branch when CI comes back red, so no rotting red proposal is left behind;
# reconcile closes froot PRs a newer patch superseded or the base already
# satisfied. Set to 0 to keep red/stale PRs open (e.g. cautious first adoption).
FROOT_CLOSE_ON_RED=1
FROOT_RECONCILE=1

# Temporal connection (these defaults are for a local server; the cluster
# deployment sets them to the in-cluster frontend / namespace / queue).
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=froot

# Changelog-judge model (a local Ollama by default).
FROOT_OLLAMA_MODEL=gemma4:e4b
FROOT_OLLAMA_URL=http://localhost:11434/v1

# OpenTelemetry off unless truthy (the cluster sets FROOT_OTEL=1).
FROOT_OTEL=0
